# .env.example — Copy to .env and fill in
# IMPORTANT: never commit .env (it's in .gitignore)

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Postgres
POSTGRES_USER=mihub
POSTGRES_PASSWORD=mihub_dev_pw
POSTGRES_DB=mihub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# LLM config
LLM_MODEL_PRIMARY=claude-sonnet-4-6
LLM_MODEL_FALLBACK=claude-haiku-4-5
EMBEDDING_MODEL=voyage-3-large

# Optional Voyage AI for embeddings (otherwise embeddings disabled, keyword search fallback)
VOYAGE_API_KEY=

# Demo settings
DEMO_MODE=cache_first
LOG_LEVEL=INFO
